# Configurações 99
TAXI99_CLIENT_ID=seu-client-id-99
TAXI99_CLIENT_SECRET=seu-client-secret-99
TAXI99_REDIRECT_URI=http://localhost:3000/api/integrations/99/callback
TAXI99_AUTH_URL=https://auth.99app.com/oauth/authorize
TAXI99_TOKEN_URL=https://auth.99app.com/oauth/token
TAXI99_API_BASE_URL=https://api.99app.com/v3

# Configurações iFood
IFOOD_CLIENT_ID=seu-client-id-ifood
IFOOD_CLIENT_SECRET=seu-client-secret-ifood
IFOOD_REDIRECT_URI=http://localhost:3000/api/integrations/ifood/callback
IFOOD_AUTH_URL=https://merchant-api.ifood.com.br/authentication/v1.0/oauth/authorize
IFOOD_TOKEN_URL=https://merchant-api.ifood.com.br/authentication/v1.0/oauth/token
IFOOD_API_BASE_URL=https://merchant-api.ifood.com.br/v1.0

# Configurações Open Banking
OPENBANKING_CLIENT_ID=seu-client-id-openbanking
OPENBANKING_CLIENT_SECRET=seu-client-secret-openbanking
OPENBANKING_REDIRECT_URI=http://localhost:3000/api/integrations/banking/callback

